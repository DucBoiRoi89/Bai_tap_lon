<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AuctionListController">
   <top>
      <VBox alignment="CENTER" prefHeight="125.0" style="-fx-background-color: #1a1a1a;"><children><Label text="UET AUCTIONS" textFill="#dca742"><font><Font size="36.0" /></font></Label></children></VBox>
   </top>
   <left>
      <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #404040;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="30.0" /></padding>
         <children>
            <Button onAction="#handleGoToHome" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0;" text="Trang chủ " />
            <Button onAction="#handleGoToProfile" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0;" text="Tài khoản " />
            <Button onAction="#handleGoToHistory" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #dca742; -fx-font-weight: bold;" text="Lịch sử đấu giá " />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="20.0" style="-fx-background-color: white;"><padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
         <children><Label text="LỊCH SỬ ĐẤU GIÁ" style="-fx-font-weight: bold; -fx-font-size: 22;" /><TableView fx:id="historyTable" stylesheets="@style.css" VBox.vgrow="ALWAYS"><columns><TableColumn prefWidth="200.0" text="Tên sản phẩm" /><TableColumn prefWidth="150.0" text="Giá bạn đặt" /><TableColumn prefWidth="150.0" text="Trạng thái" /></columns><columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy></TableView></children>
      </VBox>
   </center>
</BorderPane>