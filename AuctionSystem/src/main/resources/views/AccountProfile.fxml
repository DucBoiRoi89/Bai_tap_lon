<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AuctionListController">
   <top>
      <VBox alignment="CENTER" prefHeight="125.0" style="-fx-background-color: #1a1a1a;">
         <padding><Insets bottom="20.0" top="20.0" /></padding>
         <children><Label text="UET AUCTIONS" textFill="#dca742"><font><Font size="36.0" /></font></Label></children>
      </VBox>
   </top>
   <left>
      <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #404040;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="30.0" /></padding>
         <children>
            <Button onAction="#handleGoToHome" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0; -fx-cursor: hand;" text="Trang chủ " />
            <Button onAction="#handleGoToProfile" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #dca742; -fx-font-weight: bold; -fx-cursor: hand;" text="Tài khoản " />
            <Button onAction="#handleGoToHistory" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0; -fx-cursor: hand;" text="Lịch sử đấu giá " />
            <Region VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="30.0" style="-fx-background-color: white;">
         <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <StackPane style="-fx-background-color: #e0e0e0; -fx-background-radius: 40; -fx-min-width: 80; -fx-min-height: 80;"><children><Label text="👤" style="-fx-font-size: 40;" /></children></StackPane>
                  <VBox alignment="CENTER_LEFT"><children><Label text="Trần Tuấn Thành" style="-fx-font-weight: bold; -fx-font-size: 18;" /><Label text="Bidder / Hệ thống thông tin" textFill="#dca742" /></children></VBox>
               </children>
            </HBox>
            <GridPane hgap="15.0" vgap="15.0">
               <columnConstraints><ColumnConstraints minWidth="150.0" /><ColumnConstraints hgrow="ALWAYS" /></columnConstraints>
               <children>
                  <Label text="Mã người dùng :" GridPane.rowIndex="0" /><TextField editable="false" text="20070121" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label text="Họ và tên :" GridPane.rowIndex="1" /><TextField text="Trần Tuấn Thành" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Email :" GridPane.rowIndex="2" /><TextField editable="false" text="thanh@uet.vnu.edu.vn" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #1a1a1a; -fx-padding: 25; -fx-background-radius: 10;">
               <children><VBox HBox.hgrow="ALWAYS"><children><Label text="Hoạt động hệ thống:" textFill="WHITE" /><Label text="Số dư ví: 5,000,000 VNĐ" textFill="#dca742" style="-fx-font-size: 20;" /></children></VBox><Button style="-fx-background-color: #dca742; -fx-text-fill: white;" text="+ NẠP TIỀN " /></children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children><Button text="Đăng xuất" style="-fx-text-fill: #e74c3c; -fx-underline: true; -fx-background-color: transparent;" /><Region HBox.hgrow="ALWAYS" /><Button onAction="#handleChangePassword" text="Đổi mật khẩu " /><Button text="LƯU THAY ĐỔI" style="-fx-background-color: black; -fx-text-fill: white;" /></children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>