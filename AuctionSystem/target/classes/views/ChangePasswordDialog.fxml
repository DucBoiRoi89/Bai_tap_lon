<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: transparent; -fx-padding: 10;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AuctionListController">
   <children>
      <VBox prefWidth="420.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #dca742; -fx-border-radius: 15; -fx-border-width: 2;">
         <padding><Insets bottom="30.0" left="35.0" right="35.0" top="30.0" /></padding>
         <children>
            <Label text="ĐỔI MẬT KHẨU" style="-fx-font-weight: bold; -fx-font-size: 22;" />
            <PasswordField prefHeight="45.0" promptText="Mật khẩu hiện tại..." />
            <PasswordField prefHeight="45.0" promptText="Mật khẩu mới..." />
            <PasswordField prefHeight="45.0" promptText="Xác nhận mật khẩu mới..." />
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button onAction="#handleCloseDialog" prefHeight="40.0" prefWidth="100.0" text="Hủy bỏ" />
                  <Button prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white;" text="XÁC NHẬN" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>