<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: transparent; -fx-padding: 10;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox prefWidth="420.0" spacing="20.0" style="-fx-background-color: #dca742, white; -fx-background-radius: 20, 17; -fx-background-insets: 0, 3;">
         <padding>
            <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
         </padding>
         <children>
            <Label text="ĐỔI MẬT KHẨU" textFill="#1a1a1a">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            
                        <VBox spacing="5.0">
               <Label text="Mật khẩu hiện tại *" textFill="#666666">
                  <font>
                     <Font name="System Bold" size="12.0" />
                  </font>
               </Label>
               <PasswordField prefHeight="45.0" promptText="Nhập mật khẩu hiện tại..." style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-background-radius: 12;" />
            </VBox>
            
                        <VBox spacing="5.0">
               <Label text="Mật khẩu mới *" textFill="#666666">
                  <font>
                     <Font name="System Bold" size="12.0" />
                  </font>
               </Label>
               <PasswordField prefHeight="45.0" promptText="Nhập mật khẩu mới..." style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-background-radius: 12;" />
            </VBox>
            
                        <VBox spacing="5.0">
               <Label text="Xác nhận mật khẩu mới *" textFill="#666666">
                  <font>
                     <Font name="System Bold" size="12.0" />
                  </font>
               </Label>
               <PasswordField prefHeight="45.0" promptText="Nhập lại mật khẩu mới..." style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 12; -fx-background-radius: 12;" />
            </VBox>
            
                        <Label text="Mật khẩu xác nhận không khớp!" textFill="#e74c3c" visible="false">
               <font>
                  <Font name="System Italic" size="12.0" />
               </font>
            </Label>
            
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 12; -fx-background-radius: 12; -fx-cursor: hand;" text="Hủy bỏ" />
                  <Button prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="XÁC NHẬN" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
